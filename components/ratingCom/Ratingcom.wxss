.scrollView {
  height: 100%;
}

.showImg {
  padding: 0 2.5px;
  box-sizing: border-box;
}

.selImageView {
  width: 100%;
  height: 100%;
  position: fixed;
  background: #f7f8fa;
  z-index: 9;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  text-align: center;
}

.selImageView movable-area {
  overflow: hidden;
}